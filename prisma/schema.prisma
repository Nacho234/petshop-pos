// ---------------------------------------------------------------------------
// Plataforma de gestión comercial — schema base (Fase 1)
//
// Principios:
//  - Dominio GENÉRICO (Product, Category, Sale...), reutilizable en cualquier
//    rubro. Lo específico del rubro (pets, grooming) vive en `src/modules`.
//  - MULTI-TENANT desde el día 1: `organizationId` en toda entidad de negocio.
//    El aislamiento se aplica en la capa repository (BaseRepository), no con
//    RLS, porque el acceso es vía Prisma (Better Auth + conexión de servicio).
//  - Plata en Decimal(12,2), nunca Float.
//  - Stock: nunca se edita a mano; toda variación es un InventoryMovement.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: las URLs de conexión van en `prisma.config.ts`.
  // Runtime: driver adapter (DATABASE_URL, pooled).
  // Migraciones: datasource.url en prisma.config.ts (DIRECT_URL, directo).
}

// ----------------------------- Enums ---------------------------------------

enum Role {
  ADMIN
  EMPLEADO
}

enum PaymentMethod {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  MERCADO_PAGO
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum CashStatus {
  OPEN
  CLOSED
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  INITIAL
}

// ------------------------- Core (Capa 1) -----------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users              User[]
  settings           Settings?
  products           Product[]
  categories         Category[]
  brands             Brand[]
  suppliers          Supplier[]
  sales              Sale[]
  cashSessions       CashSession[]
  inventoryMovements InventoryMovement[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  name           String
  role           Role     @default(EMPLEADO)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]
  cashSessions CashSession[]

  @@index([organizationId])
}

model Settings {
  id             String  @id @default(cuid())
  organizationId String  @unique
  businessName   String
  legalName      String?
  taxId          String? // CUIT
  address        String?
  phone          String?
  currency       String  @default("ARS")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ----------------------- Commerce (Capa 2) ---------------------------------

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Brand {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// Prep: relación lista, módulo de compras/proveedores todavía no existe.
model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@index([organizationId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sku            String?
  barcode        String?
  categoryId     String?
  brandId        String?
  supplierId     String? // prep, sin módulo aún
  cost           Decimal  @default(0) @db.Decimal(12, 2)
  price          Decimal  @default(0) @db.Decimal(12, 2)
  taxRate        Decimal  @default(21) @db.Decimal(5, 2) // IVA %
  stock          Int      @default(0)
  minStock       Int      @default(0)
  active         Boolean  @default(true)
  imageUrl       String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand              Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId, name])
  @@index([organizationId, categoryId])
  @@index([organizationId, brandId])
}

model Sale {
  id             String     @id @default(cuid())
  organizationId String
  number         Int // correlativo por organización
  employeeId     String
  customerId     String? // prep CRM (consumidor final por ahora)
  cashSessionId  String?
  subtotal       Decimal    @db.Decimal(12, 2)
  discount       Decimal    @default(0) @db.Decimal(12, 2)
  total          Decimal    @db.Decimal(12, 2)
  status         SaleStatus @default(COMPLETED)
  createdAt      DateTime   @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee           User                @relation(fields: [employeeId], references: [id])
  cashSession        CashSession?        @relation(fields: [cashSessionId], references: [id])
  items              SaleItem[]
  payments           Payment[]
  inventoryMovements InventoryMovement[]

  @@unique([organizationId, number])
  @@index([organizationId, createdAt])
  @@index([organizationId, employeeId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  name      String // snapshot al momento de la venta
  unitPrice Decimal @db.Decimal(12, 2) // snapshot
  qty       Int
  subtotal  Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// N pagos por venta → soporta pago Mixto de forma natural.
model Payment {
  id     String        @id @default(cuid())
  saleId String
  method PaymentMethod
  amount Decimal       @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model CashSession {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  status         CashStatus @default(OPEN)
  openingAmount  Decimal    @db.Decimal(12, 2)
  countedAmount  Decimal?   @db.Decimal(12, 2)
  note           String?
  openedAt       DateTime   @default(now())
  closedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  sales        Sale[]

  @@index([organizationId, status])
}

model InventoryMovement {
  id             String       @id @default(cuid())
  organizationId String
  productId      String
  type           MovementType
  quantity       Int // firmado: +ingreso / -egreso
  reason         String?
  saleId         String?
  userId         String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])

  @@index([organizationId, productId])
  @@index([saleId])
}
